generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING") // สำหรับ Vercel Postgres
}

// 👤 ตารางผู้ใช้งาน
model User {
  id            String   @id @default(uuid())
  nationalId    String   @unique
  militaryId    String   @unique
  rank          String
  firstName     String
  lastName      String
  position      String?
  affiliation   String?
  unit          String
  gender        String?
  age           String?
  nationality   String   @default("ไทย")
  phone         String?
  email         String   @unique
  passwordHash  String    // จะถูกเข้ารหัสด้วย bcrypt
  role          String   @default("Learner") // Admin, Instructor, Learner
  avatarUrl     String?
  createdAt     DateTime @default(now())

  quizResults           QuizResult[]
  videoProgresses       VideoProgress[]
  assignmentSubmissions AssignmentSubmission[]
  discussions           Discussion[]
  auditLogs             AuditLog[]
}

// 📚 ตารางหลักสูตร
model Course {
  id          String   @id @default(uuid())
  courseCode  String   @unique // เช่น RTA-C01
  name        String
  description String
  instructor  String
  coverImage  String
  videoUrl    String?  // เผื่อวิชาที่มีแค่วิดีโอเดียว
  category    String   @default("ทั่วไป")
  createdAt   DateTime @default(now())

  chapters    Chapter[]
  questions   QuizQuestion[]
  results     QuizResult[]
  assignments Assignment[]
  discussions Discussion[]
}

// 🎬 ตารางบทเรียนย่อย (Multi-Chapter)
model Chapter {
  id         String @id @default(uuid())
  title      String
  videoUrl   String
  orderIndex Int    @default(0) // ลำดับตอน EP.1, EP.2
  
  courseId   String
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  videoProgresses VideoProgress[]
  discussions     Discussion[]
}

// 📝 ตารางข้อสอบ
model QuizQuestion {
  id            String @id @default(uuid())
  question      String
  optA          String
  optB          String
  optC          String
  optD          String
  correctAnswer String // A, B, C, หรือ D
  
  courseId      String
  course        Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// 🏆 ตารางผลการทดสอบและใบประกาศ
model QuizResult {
  id             String   @id @default(uuid())
  score          Int
  total          Int
  isPassed       Boolean
  certificateUrl String?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// 📢 ตารางประกาศข่าวสาร
model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("Info") // Info หรือ Alert
  createdAt DateTime @default(now())
}

// 📁 ตารางคลังความรู้
model KnowledgeBase {
  id        String   @id @default(uuid())
  title     String
  category  String
  fileUrl   String
  createdAt DateTime @default(now())
}

// ---------------------------------------------
// 🏢 EXTENDED ENTERPRISE MODULES (PHASE 5)
// ---------------------------------------------

// 📽️ ตารางความคืบหน้าการเรียน (Video Progress)
model VideoProgress {
  id         String   @id @default(uuid())
  isCompleted Boolean @default(false)
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId  String
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
}

// 📝 ระบบส่งการบ้าน (Assignments)
model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime?
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  fileUrl      String
  status       String   @default("Pending") // Pending, Passed, Failed
  feedback     String?
  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// 💬 กระดานถาม-ตอบ (Q&A Forum)
model Discussion {
  id         String   @id @default(uuid())
  message    String
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapterId  String?  // ผูกกับตอนเรียนเฉพาะเจาะจงได้
  chapter    Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

// 🔒 ประวัติการใช้งาน (Audit Logs & Security)
model AuditLog {
  id         String   @id @default(uuid())
  action     String   // เช่น LOGIN, DELETE_COURSE, UPDATE_ROLE
  details    String   // ข้อมูลเพิ่มเติม
  ipAddress  String?
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
